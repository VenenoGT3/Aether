    "worker:once": "tsx worker/run-once.ts",
    "payouts:once": "tsx worker/run-payouts-once.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chaos": "vitest run lib/tests/resilience.test.ts -t chaos",
