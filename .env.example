# ==============================================================================
# Aether Environment Variables
# ==============================================================================
# Copy to .env.local for development:  cp .env.example .env.local
# Production: set in Vercel (app) and Supabase (Edge Functions) — see docs/SECRETS.md

# --- Stripe webhook routing (production default: supabase) ---
# supabase = service role stays in Supabase Edge Function (recommended)
# vercel   = legacy; requires SUPABASE_SERVICE_ROLE_KEY on Vercel (not recommended)
STRIPE_WEBHOOK_HANDLER=supabase

# ==============================================================================
# Vercel / Next.js (required in production)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

STRIPE_SECRET_KEY=sk_test_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...

# Not required on Vercel when STRIPE_WEBHOOK_HANDLER=supabase (default).
# Set in Supabase Edge Function secrets instead — see docs/SECRETS.md.
# STRIPE_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-secure-random-string

# Only if STRIPE_WEBHOOK_HANDLER=vercel (legacy local testing)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================================
# Supabase Edge Function: stripe-webhook (set in Supabase Dashboard → Secrets)
# ==============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically)

# ==============================================================================
# Optional — demo / polish (Vercel, server-only)
# ==============================================================================
XAI_API_KEY=xai-...
# XAI_MODEL=grok-4.3
RESEND_API_KEY=re_...
# RESEND_FROM="Aether <notifications@yourdomain.com>"   # verified Resend sender; defaults to notifications@aether.co
SOCIAVAULT_API_KEY=sv_your_sociavault_api_key_here

# ==============================================================================
# View-sync + earnings worker (standalone Node process — `npm run worker`)
# ==============================================================================
# Redis for BullMQ. Required by `npm run worker` (NOT by `npm run worker:once`).
REDIS_URL=redis://localhost:6379

# EU paid-partnership disclosure check at clip submission (UCPD/AGCM). The
# submitted video's title/description must carry a marker like #ad or
# #sponsorizzato. block (default) = reject without one; warn = accept + log;
# off = skip. Use warn for QA accounts whose test videos lack disclosures.
# DISCLOSURE_ENFORCEMENT=block

# Which platforms the beta accepts (app + worker). Defaults to youtube.
# Expanding is a config change, e.g. BETA_PLATFORMS=youtube,tiktok — but a new
# platform also needs ownership verification wired in clip-submit.
# BETA_PLATFORMS=youtube

# Trusted view providers. At least ONE is required by the worker because views
# become real payouts. Official providers are preferred; Ayrshare stays as an
# optional fallback/aggregator.
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
AYRSHARE_API_KEY=your_optional_ayrshare_api_key_here

# Creator account linking runs in supabase/functions/social-oauth. TikTok uses
# the same client key/secret above; YouTube ownership verification needs OAuth
# client credentials in addition to the server API key.
YOUTUBE_OAUTH_CLIENT_ID=your_youtube_oauth_client_id_here
YOUTUBE_OAUTH_CLIENT_SECRET=your_youtube_oauth_client_secret_here
# NOT needed for the YouTube-only beta: YouTube links store no tokens (the
# grant is revoked right after ownership verification). Only set this when a
# provider that must keep tokens is enabled (TikTok Display API polling) —
# AES key, 32 bytes base64 (`openssl rand -base64 32`), same value on the
# social-oauth edge function and the worker.
# SOCIAL_TOKEN_ENCRYPTION_KEY=
# QA-only escape hatch: trust any https://*.vercel.app origin for OAuth
# start/redirect (anyone can deploy there — NEVER enable in production).
# SOCIAL_OAUTH_ALLOW_PREVIEW_ORIGINS=false
# Optional explicit callback base when the function URL cannot be inferred.
# SOCIAL_OAUTH_FUNCTION_URL=https://your-project.supabase.co/functions/v1/social-oauth
# YOUTUBE_MIN_INTERVAL_MS=100      # min gap between YouTube API calls
# TIKTOK_MIN_INTERVAL_MS=350       # min gap between TikTok API calls
# AYRSHARE_MIN_INTERVAL_MS=350     # min gap between Ayrshare calls

# Optional alerting: worker [ALERT] log lines are also POSTed here as
# Slack-compatible {"text": ...} JSON (stuck payouts, provider outages, …).
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional worker tuning:
# VIEW_SYNC_INTERVAL_MINUTES=10   # how often the repeatable view-sync fan-out runs
# VIEW_SYNC_BATCH_SIZE=200        # max clips synced per cycle
# WORKER_LOG_DEBUG=true           # verbose worker logs (per-clip / per-job debug lines)
# WORKER_HEARTBEAT_MINUTES=5      # how often the worker logs a heartbeat (queue depths + counters)
# WORKER_PROVIDER_ERROR_ALERT_THRESHOLD=5  # provider errors per heartbeat window before an [ALERT]
# WORKER_FRAUD_DISQUALIFY_RATE_THRESHOLD=25  # auto-disqualifications per heartbeat window before a [ALERT] (scoring-anomaly tripwire)
# WORKER_FRAUD_REPEAT_OFFENDER_MIN_EVENTS=3  # cross-campaign fraud events (7d) to flag a creator as a repeat offender
# WORKER_HEALTH_PORT=8080         # HTTP health endpoint port for orchestrator probes (0 = disabled)

# --- Distributed cache + rate limiting (app request path; optional, opt-in) ---
# When set, API rate limiting becomes fleet-wide (atomic Redis fixed-window) and
# discovery is cached with stale-while-revalidate + stampede protection. WITHOUT
# these, the app falls back to the per-process in-memory limiter and no caching
# (fully backward compatible). Use Upstash Redis REST or Vercel KV (REST, not TCP).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=********
# (Vercel KV aliases also accepted: KV_REST_API_URL / KV_REST_API_TOKEN)
# REDIS_REST_TIMEOUT_MS=1000       # per-command timeout (backpressure) before fail-open
# DISCOVER_CACHE_TTL_MS=30000      # discovery feed soft TTL (0 disables discovery caching)

# --- Sentry error tracking + performance monitoring (optional, opt-in) ---
# Error capture + tracing activate at RUNTIME only when the DSN is set; with no
# DSN the app behaves identically (Sentry no-ops). Server + edge use SENTRY_DSN;
# the browser needs the NEXT_PUBLIC_ variant.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1    # 0..1 trace sampling (default 0.1 prod / 1.0 dev)
# Build-time source-map upload (optional; only needed for readable stack traces):
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=********        # without it, source-map upload is skipped (build still succeeds)

# --- Feature flags (safe rollouts; optional) ---
# Resolve order: remote (Upstash key `flags:<name>`) > env below > safe default (on).
# Use to dark-launch or kill a feature without code changes. For an instant
# runtime override WITHOUT a redeploy, set the Upstash key:  SET flags:enable_referrals false
# FEATURE_ENABLE_REFERRALS=true
# FEATURE_ENABLE_CHALLENGES=true
# FEATURE_ENABLE_FIRST_CLIP_BONUS=true

# Anti-fraud thresholds for view-sync (a flagged clip is auto-disqualified).
# Defaults are conservative; raise to loosen, lower to tighten. Per-platform
# scaling (TikTok 1.6x / YouTube 1.0x / Instagram 0.8x) is applied on top.
# FRAUD_MAX_GROWTH_FACTOR=50      # max x-growth in a single sync (above baseline)
# FRAUD_MAX_ABSOLUTE_JUMP=5000000 # max absolute views added in a single sync
# FRAUD_FACTOR_MIN_BASELINE=1000  # skip the x-growth check below this view count
# FRAUD_SPIKE_MULTIPLIER=10       # latest delta vs the clip's recent average delta
# FRAUD_SPIKE_MIN_DELTA=100000    # ignore the spike check below this absolute delta
# FRAUD_SPIKE_MIN_HISTORY=3       # min prior per-sync deltas before spike applies
# FRAUD_BOT_MIN_SNAPSHOTS=6       # min deltas before the uniform-growth check applies
# FRAUD_BOT_CV_THRESHOLD=0.05     # coefficient of variation below this = bot-like
# FRAUD_BOT_MIN_DELTA=1000        # only judge uniformity above this avg delta/sync
# FRAUD_HISTORY_SNAPSHOTS=12      # recent snapshots loaded per clip for the checks
# Advanced bot/fake-account scoring (0–100; auto-disqualify >= disqualify score,
# flag for manual review >= flag score):
# FRAUD_ENGAGEMENT_MIN_VIEWS=20000   # only check engagement above this view count
# FRAUD_ENGAGEMENT_MIN_RATIO=0.005   # (likes+comments+shares)/views below this = bot/bought
# FRAUD_ANOMALY_WINDOW_MINUTES=10    # window after submission where big views are implausible
# FRAUD_ANOMALY_MIN_VIEWS=5000       # this many views inside the window = anomaly
# FRAUD_VIEW_DROP_MIN_VIEWS=10000    # only judge a drop above this counted baseline
# FRAUD_VIEW_DROP_PCT=0.25           # reported count this far below counted = removed/fake views
# FRAUD_CREATOR_BURST_WINDOW_MINUTES=30  # window for counting a creator's submissions
# FRAUD_CREATOR_BURST_MAX_CLIPS=8        # this many clips in the window = burst (farming)
# FRAUD_DECAY_HALF_LIFE_MINUTES=720  # half-life for time-decay of carried-over score (12h)
# FRAUD_WEIGHT_VELOCITY=80           # signal weights → combined score
# FRAUD_WEIGHT_SPIKE=35
# FRAUD_WEIGHT_BOT=40
# FRAUD_WEIGHT_ENGAGEMENT=35
# FRAUD_WEIGHT_ANOMALY=35
# FRAUD_WEIGHT_CROSS_CAMPAIGN=70
# FRAUD_WEIGHT_VIEW_DROP=45
# FRAUD_WEIGHT_CREATOR_BURST=30
# FRAUD_DISQUALIFY_SCORE=80          # auto-disqualify at/above
# FRAUD_FLAG_SCORE=50                # flag for manual review at/above

# Payout batch worker (Phase 5):
# VIEW_HOLDBACK_HOURS=48          # default settle delay before earnings are payable
#                                 # (per-campaign view_holdback_hours overrides this)
# MIN_PAYOUT_THRESHOLD=10         # min approved balance per creator before paying out
# PAYOUT_BATCH_INTERVAL=360       # how often the payout batch runs (minutes)
# WORKER_AUTO_PAYOUTS=false       # false (default) = creators withdraw manually; the batch only
#                                 # promotes accrued→approved. true = fully automated payouts.
# WITHDRAWAL_RECONCILE_STUCK_MINUTES=10  # a withdrawal stuck 'processing' longer than this is
#                                 # reconciled by the batch (re-issues the transfer idempotently)
# STRIPE_SECRET_KEY is also required by the worker for creator payouts.

# Test login shortcut (temporary QA only; Vercel/server-only). When enabled,
# /auth/login shows Brand/Creator buttons that sign into these Supabase Auth
# users through a server route. Deployed runtimes, including production beta,
# require TEST_LOGIN_ACCESS_CODE. Do not use with real-money data.
# ENABLE_TEST_LOGIN=false
# TEST_LOGIN_ACCESS_CODE=replace-with-long-random-code
# TEST_BRAND_EMAIL=brand-test@example.com
# TEST_BRAND_PASSWORD=replace-with-long-random-password
# TEST_CREATOR_EMAIL=creator-test@example.com
# TEST_CREATOR_PASSWORD=replace-with-long-random-password

# SAFETY: the worker requires at least one trusted live view source. Without one,
# earnings accrual + payouts are BLOCKED (and startup hard-fails) so real money
# is never paid out on unverified views.

# Pool-funding reconciliation (safety net for missed/delayed payment_intent.succeeded
# webhooks — activates performance campaigns stuck in 'draft' after funding):
# POOL_FUNDING_RECONCILIATION_INTERVAL_MINUTES=15  # how often the reconcile job runs
# POOL_FUNDING_STUCK_ALERT_MINUTES=120             # draft+funded longer than this → [ALERT]

# NOTE: the worker also needs NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
# (it writes view_snapshots/earnings via the service role, bypassing RLS).
