# ==============================================================================
# Aether Environment Variables
# ==============================================================================

# --- Mock mode (local demo without Supabase/Stripe) ---
# Set to true for fully offline UI demo. Set to false for production.
AETHER_MOCK_MODE=true

# Supabase (required when AETHER_MOCK_MODE=false)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe Connect (required when AETHER_MOCK_MODE=false)
STRIPE_SECRET_KEY=sk_test_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (required when AETHER_MOCK_MODE=false)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job authentication (required when AETHER_MOCK_MODE=false)
CRON_SECRET=your-secure-random-string

# --- Optional: demo / polish features ---
GEMINI_API_KEY=AIzaSy...
RESEND_API_KEY=re_...
SOCIAVAULT_API_KEY=sv_your_sociavault_api_key_here