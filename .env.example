# ==============================================================================
# Aether Environment Variables
# ==============================================================================
# Copy to .env.local for development:  cp .env.example .env.local
# Production: set in Vercel (app) and Supabase (Edge Functions) — see docs/SECRETS.md

# --- Mock mode ---
# true  = local UI demo (no real Supabase/Stripe required)
# false = production; missing required vars fail at build/startup
AETHER_MOCK_MODE=true

# --- Stripe webhook routing (production default: supabase) ---
# supabase = service role stays in Supabase Edge Function (recommended)
# vercel   = legacy; requires SUPABASE_SERVICE_ROLE_KEY on Vercel (not recommended)
STRIPE_WEBHOOK_HANDLER=supabase

# ==============================================================================
# Vercel / Next.js (required when AETHER_MOCK_MODE=false)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

STRIPE_SECRET_KEY=sk_test_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...

# Not required on Vercel when STRIPE_WEBHOOK_HANDLER=supabase (default).
# Set in Supabase Edge Function secrets instead — see docs/SECRETS.md.
# STRIPE_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-secure-random-string

# Only if STRIPE_WEBHOOK_HANDLER=vercel (legacy local testing)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================================
# Supabase Edge Function: stripe-webhook (set in Supabase Dashboard → Secrets)
# ==============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically)

# ==============================================================================
# Optional — demo / polish (Vercel, server-only)
# ==============================================================================
GEMINI_API_KEY=AIzaSy...
RESEND_API_KEY=re_...
SOCIAVAULT_API_KEY=sv_your_sociavault_api_key_here

# ==============================================================================
# View-sync + earnings worker (standalone Node process — `npm run worker`)
# ==============================================================================
# Redis for BullMQ. Required by `npm run worker` (NOT by `npm run worker:once`).
REDIS_URL=redis://localhost:6379

# Ayrshare — REAL view tracking for clips.
#   - Unset (or AETHER_MOCK_MODE=true): the worker uses the SIMULATED views
#     provider (believable growth) so the views -> earnings flow runs without it.
#   - Set (and AETHER_MOCK_MODE=false): the worker uses the REAL Ayrshare
#     provider (worker/views-provider.ts). This is the single switch to go live.
#   Earnings are real money once this is on, so validate Ayrshare view coverage
#   per platform first. Account linking (profiles.ayrshare_profile_key) is the
#   remaining piece before real tracking is fully wired.
# AYRSHARE_API_KEY=your_ayrshare_api_key_here
# AYRSHARE_MIN_INTERVAL_MS=350     # min gap between Ayrshare calls (rate limiting)

# Optional worker tuning:
# VIEW_SYNC_INTERVAL_MINUTES=10   # how often the repeatable view-sync fan-out runs
# VIEW_SYNC_BATCH_SIZE=200        # max clips synced per cycle
# WORKER_LOG_DEBUG=true           # verbose worker logs (per-clip / per-job debug lines)
# WORKER_HEARTBEAT_MINUTES=5      # how often the worker logs a heartbeat (queue depths + counters)
# WORKER_PROVIDER_ERROR_ALERT_THRESHOLD=5  # provider errors per heartbeat window before an [ALERT]

# Payout batch worker (Phase 5):
# VIEW_HOLDBACK_HOURS=48          # default settle delay before earnings are payable
#                                 # (per-campaign view_holdback_hours overrides this)
# MIN_PAYOUT_THRESHOLD=10         # min approved balance per creator before paying out
# PAYOUT_BATCH_INTERVAL=360       # how often the payout batch runs (minutes)
# STRIPE_SECRET_KEY is also required by the worker for live (non-mock) payouts.

# NOTE: the worker also needs NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
# (it writes view_snapshots/earnings via the service role, bypassing RLS). Even
# in mock mode the worker needs a real Supabase project — mock only stubs views.