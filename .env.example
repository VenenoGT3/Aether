# ==============================================================================
# Aether Environment Variables
# ==============================================================================
# Copy to .env.local for development:  cp .env.example .env.local
# Production: set in Vercel (app) and Supabase (Edge Functions) — see docs/SECRETS.md

# --- Mock mode ---
# true  = local UI demo (no real Supabase/Stripe required)
# false = production; missing required vars fail at build/startup
AETHER_MOCK_MODE=true

# --- Stripe webhook routing (production default: supabase) ---
# supabase = service role stays in Supabase Edge Function (recommended)
# vercel   = legacy; requires SUPABASE_SERVICE_ROLE_KEY on Vercel (not recommended)
STRIPE_WEBHOOK_HANDLER=supabase

# ==============================================================================
# Vercel / Next.js (required when AETHER_MOCK_MODE=false)
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

STRIPE_SECRET_KEY=sk_test_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...

# Not required on Vercel when STRIPE_WEBHOOK_HANDLER=supabase (default).
# Set in Supabase Edge Function secrets instead — see docs/SECRETS.md.
# STRIPE_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-secure-random-string

# Only if STRIPE_WEBHOOK_HANDLER=vercel (legacy local testing)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================================
# Supabase Edge Function: stripe-webhook (set in Supabase Dashboard → Secrets)
# ==============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically)

# ==============================================================================
# Optional — demo / polish (Vercel, server-only)
# ==============================================================================
GEMINI_API_KEY=AIzaSy...
RESEND_API_KEY=re_...
SOCIAVAULT_API_KEY=sv_your_sociavault_api_key_here